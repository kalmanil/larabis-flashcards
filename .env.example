# Tenant-specific environment overrides for: flashcards
#
# Loaded AFTER the base larabis/.env when DOMAIN_TENANT_ID=flashcards is set there.
# Values here override the base file for the same keys. Do not set DOMAIN_TENANT_ID in this file.
#
# Copy to .env (gitignored) and adjust. See parent ../../.env.example for full app variables.

# --- Geo: allow only Israel (403 elsewhere; requires readable MaxMind .mmdb or trusted Cloudflare header) ---
# GEO_ENFORCE=true
# GEO_MODE=global
# GEO_ALLOWED_COUNTRIES=IL
# GEO_ALLOW_UNKNOWN_COUNTRY=false
# GEO_TRUST_CLOUDFLARE_COUNTRY=false
# GEO_MAXMIND_DATABASE=
# GEO_BYPASS_CIDRS=127.0.0.1/32,::1/128

# --- Example: third-party API keys used only by this tenant ---
# LARA_ACCESS_KEY_ID=
# LARA_ACCESS_KEY_SECRET=
# GEMINI_API_KEY=
# OPENAI_API_KEY=
