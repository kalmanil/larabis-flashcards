# Tenant-specific environment overrides for: flashcards
#
# This file is loaded AFTER the base larabis/.env, so values here
# add to or override base env vars for this tenant only.
#
# Copy to .env (gitignored) and fill in real values.
# Do NOT redefine base vars (APP_KEY, DB_*, etc.) here unless you
# intentionally want to override them for this tenant.

# Lara Translate API credentials (https://app.laratranslate.com)
LARA_ACCESS_KEY_ID=
LARA_ACCESS_KEY_SECRET=

# OpenAI (word import from dashboard; optional)
OPENAI_API_KEY=

# Initial superadmin (optional password; if omitted, artisan generates one and prints it once)
FLASHCARDS_SUPERADMIN_EMAIL=
FLASHCARDS_SUPERADMIN_PASSWORD=
